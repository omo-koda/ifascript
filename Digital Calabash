    HaltIfOne,
    CastCowries,
    RequireEbo(EboTrigger),
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum EboTrigger {
    StackUnderflow,
    DivisionByZero,
    InvalidCast,
    HeapOverflow,
    ForbiddenBranch,
}

/// The Ifá Virtual Machine
pub struct IfaVM {
    stack: Vec<i32>,
    ebo_history: Vec<EboTrigger>,
    current_odu: Option<&'static Odu>,
}

impl IfaVM {
    pub fn new() -> Self {
        Self {
            stack: Vec::new(),
            ebo_history: Vec::new(),
            current_odu: None,
        }
    }
    
    /// Execute a divination program
    pub fn execute(&mut self, odu_names: Vec<&str>) -> Result<(), EboTrigger> {
        for name in odu_names {
            let odu = Odu::CORPUS.iter()
                .find(|o| o.sacred_name == name)
                .ok_or(EboTrigger::InvalidCast)?;
            
            self.current_odu = Some(odu);
            self.execute_odu(odu)?;
        }
        Ok(())
    }
    
    fn execute_odu(&mut self, odu: &Odu) -> Result<(), EboTrigger> {
        // Map Odu to opcode based on domain and Orisha resonance
        let op = self.derive_opcode(odu);
        match op {
            OduOp::PushConst(val) => self.stack.push(val),
            OduOp::PopVoid => { self.stack.pop(); },
            OduOp::Dup => {
                let val = self.stack.last().copied()
                    .ok_or(EboTrigger::StackUnderflow)?;
                self.stack.push(val);
            },
            OduOp::Swap => {
                if self.stack.len() < 2 {
                    return Err(EboTrigger::StackUnderflow);
                }
                let len = self.stack.len();
                self.stack.swap(len - 1, len - 2);
            },
            OduOp::Add => {
                let b = self.stack.pop().ok_or(EboTrigger::StackUnderflow)?;
                let a = self.stack.pop().ok_or(EboTrigger::StackUnderflow)?;
                self.stack.push(a + b);
            },
            OduOp::Sub => {
                let b = self.stack.pop().ok_or(EboTrigger::StackUnderflow)?;
                let a = self.stack.pop().ok_or(EboTrigger::StackUnderflow)?;
                self.stack.push(a - b);
            },
            OduOp::HaltIfOne => {
                if self.stack.last() == Some(&1) {
                    return Ok(());
                }
            },
            OduOp::CastCowries => {
                let cast = CowrieOracle::cast();
                println!("Àṣẹ. Cast: {} — {}", cast.sacred_name, cast.prescription);
            },
            OduOp::RequireEbo(trigger) => {
                self.ebo_history.push(trigger);
                return Err(trigger);
            },
        }
        Ok(())
    }
    
    fn derive_opcode(&self, odu: &Odu) -> OduOp {
        // Derive opcode from Odu properties
        match odu.domain {
            (AiDomain::Genesis, _) | (_, AiDomain::Genesis) => {
                OduOp::PushConst(odu.canonical_index as i32)
            },
            (AiDomain::Execution, _) | (_, AiDomain::Execution) => {
                if self.stack.len() >= 2 {
                    OduOp::Add
                } else {
                    OduOp::CastCowries
                }
            },
            (AiDomain::Ethics, _) | (_, AiDomain::Ethics) => {
                OduOp::HaltIfOne
            },
            _ => OduOp::Dup,
        }
    }
    
    /// Get the sacred output — Àṣẹ
    pub fn ase(&self) -> String {
        match self.current_odu {
            Some(odu) => format!("Àṣẹ. {} — {}", odu.sacred_name, odu.prescription),
            None => "Àṣẹ. No Odu cast.".to_string(),
        }
    }
}

