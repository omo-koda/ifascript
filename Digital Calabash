    /// Cast the cowries — derive an Odu from entropy
    pub fn cast(entropy: u16) -> &'static Odu {
        let index = (entropy % 256) as usize;
        &Self::CORPUS[index]
    }
    
    /// Cast with ritual intent — deterministic from intent string
    pub fn cast_with_intent(intent: &str) -> &'static Odu {
        use std::collections::hash_map::DefaultHasher;
        use std::hash::{Hash, Hasher};
        
        let mut hasher = DefaultHasher::new();
        intent.hash(&mut hasher);
        let hash = hasher.finish() as u16;
        Self::cast(hash)
    }
    
    /// Get Odu by canonical index (1-256)
    pub fn by_index(index: u16) -> Option<&'static Odu> {
        if index == 0 || index > 256 {
            None
        } else {
            Some(&Self::CORPUS[(index - 1) as usize])
        }
    }
    
    /// Get Odu by binary pattern
    pub fn by_binary(pattern: &[Mark; 16]) -> Option<&'static Odu> {
        Self::CORPUS.iter().find(|odu| &odu.binary_marks == pattern)
    }
    
    /// Get all Odù for a given domain
    pub fn by_domain(domain: AiDomain) -> Vec<&'static Odu> {
        Self::CORPUS.iter()
            .filter(|odu| odu.domain.0 == domain || odu.domain.1 == domain)
            .collect()
    }
    
    /// Get all Odù governed by an Orisha
